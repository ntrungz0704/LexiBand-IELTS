rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return (request.auth != null && request.auth.uid == userId) || (userId is string && userId.matches('^custom_.*'));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation for CustomAuth entity
    function isValidCustomAuth(data) {
      return data.uid is string && data.uid.size() <= 128
        && data.email is string && data.email.size() <= 256
        && data.displayName is string && data.displayName.size() <= 128
        && data.password is string && data.password.size() <= 128
        && (data.createdAt == null || data.createdAt is string);
    }

    // Validation for User entity
    function isValidUser(data) {
      return data.email is string && data.email.size() <= 256
        && data.displayName is string && data.displayName.size() <= 128
        && (data.createdAt == null || data.createdAt is string)
        && (data.updatedAt == null || data.updatedAt is string);
    }

    // Validation for UserProgressDoc entity
    function isValidProgress(data) {
      return data.progress is map
        && (data.updatedAt == null || data.updatedAt is string);
    }

    // Validation for StreakDoc entity
    function isValidStreak(data) {
      return data.currentStreak is int && data.currentStreak >= 0
        && data.longestStreak is int && data.longestStreak >= 0
        && data.history is map
        && (data.lastActiveDate == null || data.lastActiveDate is string)
        && (data.updatedAt == null || data.updatedAt is string);
    }

    // Validation for LearningPlanDoc entity
    function isValidLearningPlan(data) {
      return data.startBand is string && data.startBand.size() <= 32
        && data.targetBand is string && data.targetBand.size() <= 32
        && data.durationMonths is int && data.durationMonths >= 0
        && data.dailyUnits is list
        && (data.updatedAt == null || data.updatedAt is string);
    }

    // Collection matches
    match /custom_auth/{emailId} {
      allow get: if true;
      allow create: if isValidCustomAuth(incoming());
    }

    match /users/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      allow create: if isOwner(userId) && isValidId(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidId(userId) && isValidUser(incoming())
        && incoming().createdAt == existing().createdAt; // Immutable createdAt

      match /userData/progress {
        allow get: if isOwner(userId) && isValidId(userId);
        allow create, update: if isOwner(userId) && isValidId(userId) && isValidProgress(incoming());
      }

      match /userData/streak {
        allow get: if isOwner(userId) && isValidId(userId);
        allow create, update: if isOwner(userId) && isValidId(userId) && isValidStreak(incoming());
      }

      match /userData/learningPlan {
        allow get: if isOwner(userId) && isValidId(userId);
        allow create, update: if isOwner(userId) && isValidId(userId) && isValidLearningPlan(incoming());
      }

      match /userData/errorBank {
        allow get: if isOwner(userId) && isValidId(userId);
        allow create, update: if isOwner(userId) && isValidId(userId);
      }
    }
  }
}
